generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  DR
  CR
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum DeviceStatus {
  AVAILABLE
  BILLED
}

model Customer {
  id           String        @id @default(uuid())
  name         String
  phone        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  bills        Bill[]
}

model Transaction {
  id          String          @id @default(uuid())
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  paymentMode PaymentMode
  deviceId    String          @db.VarChar(30)
  vehicleId   String          @db.VarChar(30)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Bill {
  id                String           @id @default(uuid())
  customerId        String
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billDate          DateTime
  invoiceNo         String           @db.VarChar(40)
  vehicleId         String
  vltdSerialNo      String
  vltdImeiNo        String
  deviceId          String           @db.VarChar(30)
  inventoryDeviceId String?           @unique
  inventoryDevice   DeviceInventory?  @relation("PrimaryBillDevice", fields: [inventoryDeviceId], references: [id], onDelete: SetNull)
  inventoryDevices  DeviceInventory[] @relation("BillInventoryDevices")
  subtotal          Decimal           @db.Decimal(10, 2)
  gstAmount         Decimal          @db.Decimal(10, 2)
  totalAmount       Decimal          @db.Decimal(10, 2)
  customerGst       String?
  notes             String?
  items             BillItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model DeviceInventory {
  id               String       @id @default(uuid())
  vltdSerialNo     String       @unique @db.VarChar(40)
  imeiNo           String       @db.VarChar(20)
  deviceNo         String?      @db.VarChar(20)
  iccid            String?      @db.VarChar(25)
  qrCode           String?      @db.VarChar(120)
  billingCompany   String?      @db.VarChar(80)
  dispatchCustomer String?      @db.VarChar(80)
  pcba             String?      @db.VarChar(40)
  dispatchHex      String?      @db.VarChar(40)
  scanBy           String?      @db.VarChar(40)
  status           DeviceStatus @default(AVAILABLE)
  bill             Bill?        @relation("PrimaryBillDevice")
  billedBillId     String?
  billedBill       Bill?        @relation("BillInventoryDevices", fields: [billedBillId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model BillItem {
  id          String  @id @default(uuid())
  billId      String
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  description String
  hsn         String  @default("85269190") @db.VarChar(12)
  quantity    Decimal @db.Decimal(10, 2)
  per         String  @default("PCS") @db.VarChar(10)
  unitPrice   Decimal @db.Decimal(10, 2)
  rateInclTax Decimal @db.Decimal(10, 2)
  discPercent Decimal @default(0) @db.Decimal(5, 2)
  amount      Decimal @db.Decimal(10, 2)
}
